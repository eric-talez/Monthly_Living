{
  "name": "handalsalgi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typegen": "next typegen",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:watch": "vitest",
    "e2e:prepare": "tsx scripts/e2e-prepare.ts",
    "test:e2e": "pnpm e2e:prepare && playwright test",
    "test:e2e:ui": "pnpm e2e:prepare && playwright test --ui",
    "db:format": "prisma format",
    "db:validate": "prisma validate",
    "db:generate": "prisma generate",
    "db:migrate:draft": "prisma migrate dev --create-only",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:test:prepare": "tsx scripts/db-test-prepare.ts",
    "db:reset": "tsx scripts/db-reset.ts --dev",
    "db:reset:test": "tsx scripts/db-reset.ts --test"
  },
  "dependencies": {
    "@auth/prisma-adapter": "2.11.2",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "next": "16.2.10",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.13.2",
    "pg": "8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@auth/core": "0.41.2",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "7.8.0",
    "tailwindcss": "^4",
    "tsx": "4.23.0",
    "typescript": "^5",
    "vitest": "4.1.10"
  }
}

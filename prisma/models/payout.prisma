// ── Payout: 정산 원장 (실제 자동 송금 없음 — 관리자 수동 지급 관리) ─
// Payout 원본 금액은 생성 후 수정하지 않는다.
// 환불·chargeback·수동 조정은 PayoutAdjustment에 append-only로만 기록한다.
// 최종 지급액 = payoutAmount + SUM(adjustments.amount)  (조정 금액은 음수 가능)
//
// 앱 레이어 필수 불변식 (docs/decisions/database-constraints.md §3):
// - Payout.expertId = Booking.expertId, Payout.currency = Booking.currency
// - Payout 생성은 Booking COMPLETED 처리와 같은 transaction에서 수행

model Payout {
  id               String       @id @default(cuid())
  expertId         String
  bookingId        String       @unique // 예약당 원장 엔트리 1건
  grossAmount      Int // 예약 총액 중 전문가 몫 계산 기준 (minor units)
  platformFee      Int
  payoutAmount     Int // 생성 시점 확정 지급 예정액 — 이후 조정은 PayoutAdjustment로
  currency         Currency
  status           PayoutStatus @default(PENDING)
  scheduledAt      DateTime?    @db.Timestamptz(6)
  approvedAt       DateTime?    @db.Timestamptz(6)
  paidAt           DateTime?    @db.Timestamptz(6) // 관리자가 외부 송금 후 수동 기록
  paidById         String?
  paymentReference String? // 외부 송금 참조 번호
  note             String?
  createdAt        DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt        DateTime     @updatedAt @db.Timestamptz(6)

  expert  ExpertProfile @relation(fields: [expertId], references: [id], onDelete: Restrict)
  booking Booking       @relation(fields: [bookingId], references: [id], onDelete: Restrict)
  paidBy  User?         @relation("PayoutPayer", fields: [paidById], references: [id], onDelete: SetNull)

  adjustments PayoutAdjustment[]

  @@index([expertId, status])
  @@index([status, scheduledAt])
}

// append-only 정산 조정 기록 — 이미 PAID된 금액을 덮어쓰지 않기 위한 구조.
// 통화 필드는 두지 않는다: adjustment의 통화는 항상 부모 Payout.currency를 따른다
// (서로 다른 통화의 정수 합산 사고 방지 — docs/decisions/database-constraints.md §3).
model PayoutAdjustment {
  id          String               @id @default(cuid())
  payoutId    String
  type        PayoutAdjustmentType
  amount      Int // signed, 부모 Payout.currency 단위 — 차감은 음수 (CHECK amount <> 0)
  reason      String
  createdById String?
  createdAt   DateTime             @default(now()) @db.Timestamptz(6)

  payout    Payout @relation(fields: [payoutId], references: [id], onDelete: Restrict)
  createdBy User?  @relation("AdjustmentCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([payoutId])
}

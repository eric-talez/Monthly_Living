# ============================================================
# 한달살기 — 환경변수 예시
# 이 파일을 복사해 .env.local을 만들고 값을 채운다.
#   cp .env.example .env.local
# 실제 secret은 절대 저장소에 커밋하지 않는다.
# 새 환경변수를 추가하면 src/lib/env.ts의 스키마에도 반드시 등록한다.
# ============================================================

# ── 현재 사용 중 ────────────────────────────────────────────
# 앱 기본 URL (생략 시 http://localhost:3000)
APP_URL=http://localhost:3000

# PostgreSQL 연결 (생략 시 로컬 기본값 postgresql://localhost:5432/handalsalgi_dev)
# production/staging에서는 반드시 명시적으로 설정한다.
DATABASE_URL=postgresql://localhost:5432/handalsalgi_dev

# 통합 테스트 전용 DB (Phase 1B-2부터 사용 — 이름에 _test 필수)
# TEST_DATABASE_URL=postgresql://localhost:5432/handalsalgi_test

# ── Phase 1C 이후 사용 예정 ──────────────────────────────────
# AUTH_SECRET=            # `openssl rand -base64 32` 로 직접 생성
# AUTH_GOOGLE_ID=         # (선택) Google OAuth — 값이 있으면 소셜 로그인 활성화
# AUTH_GOOGLE_SECRET=
# AUTH_KAKAO_ID=          # (선택) Kakao OAuth
# AUTH_KAKAO_SECRET=

# ── Phase 4~5 이후 사용 예정 ─────────────────────────────────
# STORAGE_LOCAL_PATH=.storage        # LocalFsStorageProvider 저장 경로
# STORAGE_SIGNING_SECRET=            # 파일 다운로드 서명용 — 직접 생성
# PAYMENT_PROVIDER=mock              # mock | stripe
# PAYMENT_WEBHOOK_SECRET=            # mock webhook HMAC 서명용 — 직접 생성
# STRIPE_SECRET_KEY=                 # (선택) sk_test_... 입력 시 Stripe 테스트 모드
# STRIPE_WEBHOOK_SECRET=

# ── Phase 6 이후 사용 예정 ───────────────────────────────────
# EMAIL_PROVIDER=console             # console | resend
# RESEND_API_KEY=
# EMAIL_FROM=

# ── 출시 Gate 관련 (선택, 키 입력 시 활성화) ─────────────────
# SENTRY_DSN=
# POSTHOG_KEY=
# REDIS_URL=

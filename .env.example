# ============================================================
# 한달살기 — 환경변수 예시
# 이 파일을 복사해 .env.local을 만들고 값을 채운다.
#   cp .env.example .env.local
# 실제 secret은 절대 저장소에 커밋하지 않는다.
# 새 환경변수를 추가하면 src/lib/env.ts의 스키마에도 반드시 등록한다.
# ============================================================

# ── 현재 사용 중 ────────────────────────────────────────────
# 앱 기본 URL (생략 시 http://localhost:3000)
APP_URL=http://localhost:3000

# PostgreSQL 연결 — fail-closed: 미설정이면 DB CLI/런타임 초기화가 명확하게 실패한다.
# 자동 fallback 없음. production/staging에서 localhost 사용 금지.
# (Homebrew 로컬처럼 OS 계정 trust 인증이면 USER:PASSWORD@ 부분은 생략 가능)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/handalsalgi_dev

# 통합 테스트 전용 DB — 이름에 _test 필수 (scripts/db-reset.ts가 강제)
TEST_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/handalsalgi_test

# Playwright E2E 전용 DB — tooling-only 변수다 (앱 runtime env·src/lib/env.ts와 무관).
# scripts/e2e-prepare.ts·tests/e2e helper만 직접 읽고, E2E 서버에는 이 값이 DATABASE_URL로
# 전달된다. 이름에 _test 필수(guard 재사용). 로컬은 trust 인증이면 USER:PASSWORD@ 생략 가능.
E2E_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/handalsalgi_e2e_test

# Auth.js JWT 서명·암호화 + rate limit 키 HMAC — fail-closed: 미설정이면 기동 실패.
# 반드시 직접 생성한다: openssl rand -base64 32  (32자 이상, 저장소 커밋 금지)
AUTH_SECRET=

# 이메일 어댑터 — Phase 1C는 console만 지원 (개발: 본문+인증 URL 출력 / production: 메타데이터만)
EMAIL_PROVIDER=console

# 프록시(로드밸런서) 뒤에서 self-host로 production 배포할 때만 명시적으로 활성화한다.
# 개발 환경(NODE_ENV != production)에서는 Auth.js가 host를 자동 신뢰하므로 불필요.
# AUTH_TRUST_HOST=true

# ── OAuth 소셜 로그인 (선택) ─────────────────────────────────
# provider별로 ID와 SECRET을 **모두** 설정해야 활성화된다.
# 하나만 설정하거나 빈 값/공백만 넣으면 fail-closed로 기동이 실패한다 (src/lib/env.ts).
# 실제 credential은 절대 저장소에 커밋하지 않는다.
#
# Google (https://console.cloud.google.com/apis/credentials):
#   승인된 리디렉션 URI에 {APP_URL}/api/auth/callback/google 등록
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
#
# Kakao (https://developers.kakao.com/console/app):
#   Redirect URI에 {APP_URL}/api/auth/callback/kakao 등록,
#   카카오 로그인 동의항목에서 카카오계정(이메일) 동의 활성화 필수
#   (이메일 미제공·미검증 계정은 로그인이 거부된다 — 결정 문서 참고)
# AUTH_KAKAO_ID=
# AUTH_KAKAO_SECRET=

# ── Phase 4~5 이후 사용 예정 ─────────────────────────────────
# STORAGE_LOCAL_PATH=.storage        # LocalFsStorageProvider 저장 경로
# STORAGE_SIGNING_SECRET=            # 파일 다운로드 서명용 — 직접 생성
# PAYMENT_PROVIDER=mock              # mock | stripe
# PAYMENT_WEBHOOK_SECRET=            # mock webhook HMAC 서명용 — 직접 생성
# STRIPE_SECRET_KEY=                 # (선택) sk_test_... 입력 시 Stripe 테스트 모드
# STRIPE_WEBHOOK_SECRET=

# ── Phase 6 이후 사용 예정 ───────────────────────────────────
# RESEND_API_KEY=                    # EMAIL_PROVIDER=resend 전환 시 필요
# EMAIL_FROM=

# ── 출시 Gate 관련 (선택, 키 입력 시 활성화) ─────────────────
# SENTRY_DSN=
# POSTHOG_KEY=
# REDIS_URL=

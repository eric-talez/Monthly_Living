# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# Claude Code 로컬 설정 (개인 환경용 — 공유 필요 시 명시적으로 해제)
.claude/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# 비공개 업로드 파일 로컬 저장소 (LocalFsStorageProvider)
/.storage/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
